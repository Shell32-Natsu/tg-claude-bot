# Copy to .env and fill in real values. Never commit .env.

# From @BotFather (required)
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token

# Long-lived Claude subscription token. Generate one on any machine where you
# are logged in to Claude Code with your Max/Pro account: `claude setup-token`.
# Required in Docker; optional locally if `claude login` has already been run.
CLAUDE_CODE_OAUTH_TOKEN=paste-the-token-printed-by-claude-setup-token

# Optional model override (alias like "sonnet"/"opus" or a full model ID).
# Leave empty to use your subscription's default model.
CLAUDE_MODEL=

# Access control (required unless ALLOW_ALL=true): comma-separated lists of
# numeric Telegram IDs or @usernames. A message is processed only if its
# chat is in ALLOWED_CHATS or its sender is in ALLOWED_USERS; everything
# else is silently dropped (and logged with the IDs, so send the bot a
# message once to discover yours). Numeric IDs are recommended — usernames
# can be changed or reassigned. Set ALLOW_ALL=true to open the bot to
# everyone instead.
ALLOWED_USERS=
ALLOWED_CHATS=
ALLOW_ALL=

# Optional session lifecycle overrides. A chat's session is dropped after
# this much inactivity (default 60 minutes) and unconditionally restarted
# with fresh context after this many days (default 7).
SESSION_IDLE_MINUTES=
SESSION_MAX_AGE_DAYS=

# Optional Telegram Bot API base URL, for self-hosted Bot API servers.
# Defaults to https://api.telegram.org
TELEGRAM_API_BASE=

# Optional path to the Claude Code binary (defaults to `claude` on PATH).
# The standard CLAUDE_CONFIG_DIR variable is also honored if set.
CLAUDE_BIN=

# Optional system prompt appended to Claude Code's default prompt. Must stay
# on one line — env files don't support multiline values.
SYSTEM_PROMPT=Always reply in the same language the user writes in. Be accurate: never guess or make up facts. If you are not sure about something, use web search to verify before answering; if you still cannot verify it, say so plainly instead of speculating. Keep replies concise; this is a chat app.
