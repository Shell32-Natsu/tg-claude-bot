# Copy to .env and fill in real values. Never commit .env.

# From @BotFather (required)
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token

# From https://console.anthropic.com (required)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional; defaults to claude-sonnet-5
CLAUDE_MODEL=claude-sonnet-5

# Optional system prompt prepended to every request. Must stay on one line —
# env files don't support multiline values.
SYSTEM_PROMPT=Always reply in the same language the user writes in. Be accurate: never guess or make up facts. If you are not sure about something, use web search to verify before answering; if you still cannot verify it, say so plainly instead of speculating.
