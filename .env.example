# Copy to .env and fill in real values. Never commit .env.

# From @BotFather (required)
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token

# From https://console.anthropic.com (required)
ANTHROPIC_API_KEY=sk-ant-replace-with-your-key

# Optional; defaults to claude-sonnet-5
CLAUDE_MODEL=claude-sonnet-5

# Optional system prompt prepended to every request
SYSTEM_PROMPT=
